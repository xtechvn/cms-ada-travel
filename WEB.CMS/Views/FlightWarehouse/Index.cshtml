@{
    ViewData["Title"] = "Kho vé máy bay";
}
<style>
    .white-popup {
        max-width: 1200px !important;
        min-height: 500px !important;
    }
</style>

<section class="main-container">
    <div class="row-main container">
        <h2 class="title_page">Kho vé máy bay</h2>
        <div class="bg_white filter-search">
            <div class="row">
                <div class="col-md-2 mb10" style="display:none">
                    <input type="hidden" class="form-control" id="search-booking-code" placeholder="Mã booking">
                </div>
                <div class="col-md-2 mb10">
                    <select type="text" class="form-control service-fly-select-route-from-departure" id="search-departure" multiple="multiple" placeholder="Điểm đi"></select>
                </div>
                <div class="col-md-2 mb10">
                    <select type="text" class="form-control service-fly-select-route-from-arrival" id="search-arrival" multiple="multiple" placeholder="Điểm đến"></select>
                </div>
                <div class="col-md-2 mb10" style="display:none">
                    <input type="text" class="form-control" id="search-airline" placeholder="Hãng bay">
                </div>
                <div class="col-md-2 mb10">
                    <select type="text" class="form-control" id="Date">
                        <option value="0">Chọn Tháng</option>
                        <option value="1">Tháng 1</option>
                        <option value="2">Tháng 2</option>
                        <option value="3">Tháng 3</option>
                        <option value="4">Tháng 4</option>
                        <option value="5">Tháng 5</option>
                        <option value="6">Tháng 6</option>
                        <option value="7">Tháng 7</option>
                        <option value="8">Tháng 8</option>
                        <option value="9">Tháng 9</option>
                        <option value="10">Tháng 10</option>
                        <option value="11">Tháng 11</option>
                        <option value="12">Tháng 12</option>
                    </select>
                </div>
                <div class="col-md-4 mb10">
                    <button class="btn btn-default" onclick="_flight_warehouse.Search()">Tìm kiếm</button>
                    <button class="btn btn-success" onclick="_flight_warehouse.Upsert(0)">Thêm mới</button>
                </div>
            </div>
        </div>
        <div id="grid-data">
            <!-- List data will be loaded here -->
        </div>
    </div>
</section>

@section scripts {
    <script src="~/modules/flight_warehouse.js" asp-append-version="true"></script>
    <script type="text/javascript" src="~/modules/order_detail_html.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            _flight_warehouse.Init();
        });
    </script>
}
