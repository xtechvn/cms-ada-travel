@using Entities.ViewModels
@using Utilities
@using Entities.ViewModels.FlightWarehouse
@model GenericViewModel<FlightWarehouseHoldTicketViewModel>

@if (Model != null && Model.ListData != null && Model.ListData.Count > 0)
{
    <div class="table-responsive bg_white">
        <table class="table table-bordered table-hover mb-0">
            <thead>
                <tr class="bg-light">
                    <th class="text-center text-uppercase text-muted font-weight-bold align-middle" style="width: 50px; font-size: 13px;">STT</th>
                    <th class="text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">SALE / KHÁCH HÀNG</th>
                    <th class="text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">CHẶNG BAY / MÃ VÉ (SERIES)</th>
                    <th class="text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">NGÀY KHỞI HÀNH</th>
                    <th class="text-center text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">SỐ LƯỢNG <i class="fa fa-info-circle text-muted"></i></th>
                    <th class="text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">GIÁ BÁN <i class="fa fa-info-circle text-muted"></i></th>
                    <th class="text-right text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">TỔNG GIÁ</th>
                    <th class="text-center text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">TRẠNG THÁI</th>
                    <th class="text-center text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">Thời gian hết hạn</th>
                    <th class="text-center text-uppercase text-muted font-weight-bold align-middle" style="font-size: 13px;">Đơn hàng</th>
                    <th class="text-center text-uppercase text-muted font-weight-bold align-middle" style="width: 80px; font-size: 13px;">THAO TÁC</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int stt = (Model.CurrentPage - 1) * Model.PageSize;
                }
                @foreach (var item in Model.ListData)
                {
                    stt++;

                    <tr>
                        <td class="text-center font-weight-bold align-middle">@stt.ToString("00")</td>
                        <td class="align-middle">
                            <div class="font-weight-bold text-dark mb-1">
                                @item.FullName

                            </div>

                        </td>
                        <td class="align-middle">
                            <div class="font-weight-bold text-dark mb-1">@item.DeparturePointName (@item.DeparturePoint)  <i class="fa fa-arrow-right mx-1 text-muted"></i> @item.ArrivalPointName (@item.ArrivalPoint)</div>
                            <div class="text-muted small">MÃ CHUYẾN BAY: @item.FlightCodeGo</div>
                            <div class="text-muted small">MÃ ĐẶT CHỖ: @item.FlightPNRCodeGo</div>

                            @if (item.TripType == 1)
                            {
                                <div class="text-muted small">Chiều đi</div>
                            }
                            else
                            {
                                <div class="text-muted small">Khứ hồi</div>
                            }
                        </td>
                        <td class="align-middle">
                            <div class="text-dark mb-1 font-weight-bold">
                                @(item.DepartureDate.HasValue? item.DepartureDate.Value.ToString("dd/MM/yyyy HH:mmm") : "---")
                            </div>
                            <div class="text-muted small">
                                @(item.ArrivalDate.HasValue? item.ArrivalDate.Value.ToString("dd/MM/yyyy HH:mmm"): "")
                            </div>
                        </td>
                        <td class="text-center align-middle">
                            <div class="font-weight-bold mb-1" style="font-size: 18px; color: #111;">@(item.AdultQuantity + item.ChildQuantity + item.InfantQuantity)</div>
                            <div class="small text-muted">
                                @item.AdultQuantity<span class="text-dark font-weight-bold">NL</span> &bull;
                                @item.ChildQuantity<span class="text-primary font-weight-bold">TE</span> &bull;
                                @item.InfantQuantity<span class="text-success font-weight-bold">EB</span>
                            </div>
                        </td>
                        <td class="align-middle">
                            <div class="small" style="line-height: 1.6;">
                                <div><span class="text-muted">NL:</span> <span class="text-dark font-weight-bold">@item.AdultAmount.ToString("N0")</span></div>
                                <div><span class="text-muted">TE:</span> <span class="text-primary font-weight-bold">@item.ChildAmount.ToString("N0")</span></div>
                                <div><span class="text-muted">EB:</span> <span class="text-success font-weight-bold">@item.InfantAmount.ToString("N0")</span></div>
                            </div>
                        </td>
                        <td class="text-right align-middle">
                            <div class="font-weight-bold" style="font-size: 15px; color: #111;">@item.TotalAmount.ToString("N0")</div>
                        </td>
                        <td class="text-center align-middle">
                            @if (item.Status == 1)
                            {
                                <span class="badge badge-success px-2 py-1" style="font-size: 11px;"><i class="fa fa-circle mr-1" style="font-size: 8px;"></i>ĐÃ CHỐT</span>
                            }
                            else if (item.Status == 2)
                            {
                                <span class="badge badge-danger px-2 py-1" style="font-size: 11px;"><i class="fa fa-circle mr-1" style="font-size: 8px;"></i>HỦY BỎ</span>
                            }
                            else if (item.Status == 0 && item.ExpirationDate > DateTime.Now)
                            {
                                <span class="badge badge-warning text-white px-2 py-1" style="font-size: 11px;"><i class="fa fa-circle mr-1" style="font-size: 8px;"></i>ĐANG GIỮ</span>
                            }
                            else if (item.Status == 0 && item.ExpirationDate < DateTime.Now)
                            {
                                <span class="badge badge-warning text-white px-2 py-1" style="font-size: 11px;"><i class="fa fa-circle mr-1" style="font-size: 8px;"></i>HẾT HẠN</span>
                            }
                        </td>
                        <td class="text-center align-middle">
                            <div class="font-weight-bold" style="font-size: 15px; color: #111;">@(((DateTime)item.ExpirationDate).ToString("dd/MM/yyyy HH:mm"))</div>
                        </td>
                        <td class="text-center align-middle">
                            <div class="font-weight-bold" style="font-size: 15px; color: #111;"><a href="/Order/@item.OrderId"> @(item.OrderNo)</a> </div>
                        </td>
                        <td class="text-center align-middle">
                            @if (item.Status == (int)Utilities.Contants.FlightWarehouseHoldTicketStatus.HOLD && item.ExpirationDate > DateTime.Now) // Không hiển thị nếu đã hủy
                            {
                                <a class="text-success mr-2" title="Tạo đơn hàng nhanh" href="javascript:;" onclick="_flight_warehouse_hold_ticket_index.QuickOrderManual(@item.Id, @item.FlightWarehouseBookingId)"><i class="fa fa-cart-plus" style="font-size: 18px;"></i></a>
                            }
                            <a class="text-info" title="Xem chi tiết" href="/FlightWarehouse/Detail?id=@item.FlightWarehouseBookingId" target="_blank"><i class="fa fa-eye" style="font-size: 18px;"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Component.InvokeAsync("PagingNew", new
    {
        pageModel = new Paging()
        {
            TotalRecord = Model.TotalRecord,
            TotalPage = Model.TotalPage,
            CurrentPage = Model.CurrentPage,
            PageSize = Model.PageSize,
            RecordName = "yêu cầu",
            PageAction = "_flight_warehouse_hold_ticket_index.OnPaging({0})",
            PageSelectPageSize = "_flight_warehouse_hold_ticket_index.onSelectPageSize()"
        }
    })
}
else
{
    <div class="table-responsive bg_white border rounded p-3 text-center">
        <p class="mb-0">Không có dữ liệu hiển thị</p>
    </div>
}
