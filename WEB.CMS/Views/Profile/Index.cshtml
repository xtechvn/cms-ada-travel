@{
    ViewData["Title"] = "Quản lý hồ sơ nghiệp vụ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row-main container">
    <div class="flex row-main-head">
        <h2 class="title_page">Quản lý hồ sơ nghiệp vụ</h2>
        <div class="btn-right text-right">
            <button type="button" class="btn btn-default" onclick="_profile.ShowUpsert(0)">
                <i class="fa fa-plus"></i> Tạo hồ sơ
            </button>
        </div>
    </div>

    <div class="bg-serach-main flex row-main-head">
        <div class="search-wrapper dynamic-dom">
            <input type="text" class="input_search" id="SearchName" placeholder="Nhập tên hồ sơ">
            <span class="search-btn">
                <button type="button" onclick="_profile.Search()">
                    <svg class="icon-svg">
                        <use xlink:href="/images/icons/icon.svg#search"></use>
                    </svg>
                </button>
            </span>
        </div>
        <div class="form-group mb0 ml-2" style="min-width: 200px;">
            <select class="form-control select2" id="SearchStatus" onchange="_profile.Search()">
                <option value="-1">Tất cả trạng thái</option>
                <option value="0">Nháp</option>
                <option value="1">Chờ duyệt</option>
                <option value="2">Từ chối</option>
                <option value="3">Đã duyệt</option>
                <option value="4">Hoàn thành</option>
            </select>
        </div>
        <button type="button" class="btn btn-default bg-main ml-2" onclick="_profile.Search()">
            Tìm kiếm
        </button>
    </div>

    <div class="wrap_bg wrap_bg_no-padding mb20" id="grid-data">
        <!-- Search results will be loaded here -->
    </div>
</div>

@section scripts {
    <script src="~/modules/profile.js"></script>
}
