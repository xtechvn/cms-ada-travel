@using Entities.Models
@model Document

<div class="form-default">
    <div class="form-group mb15">
        <label class="lbl">Vị trí lưu trữ bản cứng</label>
        <div class="wrap_input">
            <select class="form-control" id="PhysicalStorageLocation">
                <option value="">Chọn vị trí lưu trữ bản cứng</option>
                <option value="1" selected="@(Model.PhysicalStorageLocation == "Kho A")">Kho A</option>
                <option value="2" selected="@(Model.PhysicalStorageLocation == "Kho B")">Kho B</option>
                <option value="3" selected="@(Model.PhysicalStorageLocation == "Văn phòng")">Văn phòng</option>
            </select>
        </div>
    </div>
    <div class="form-group mb15">
        <label class="lbl">Vị trí lưu file mềm</label>
        <div class="wrap_input">
            <select class="form-control" id="DigitalStorageLocation">
                <option value="">Chọn vị trí lưu file mềm</option>
                <option value="1" selected="@(Model.DigitalStorageLocation == "Google Drive")">Google Drive</option>
                <option value="2" selected="@(Model.DigitalStorageLocation == "OneDrive")">OneDrive</option>
                <option value="3" selected="@(Model.DigitalStorageLocation == "Server")">Server</option>
            </select>
        </div>
    </div>
    <div class="text-right">
        <button type="button" class="btn btn-default bg-main" id="btn-finish-submit-popup">
            <i class="fa fa-check"></i> Hoàn thành
        </button>
        <button type="button" class="btn btn-default" onclick="_profile.ClosePopup()">
            Đóng
        </button>
    </div>
</div>

<script>
    $(document).ready(function () {
        _profile.InitFinishPopup(@Model.Id);
    });
</script>
