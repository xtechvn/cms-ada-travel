                        <a href="#" class="w-8 h-8 rounded-full bg-[#ff0000] text-white flex items-center justify-center hover:opacity-80 transition-opacity">
                            <i class="fa-brands fa-youtube text-sm"></i>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Note auto-generate -->
            <div class="text-center text-[10px] text-gray-400 mt-8">
                Email này được gửi tự động từ hệ thống, vui lòng không trả lời email này.
            </div>
            <!-- ========================================== -->
            <!-- ACTION BUTTONS (Hủy / Xác nhận) - Added here -->
            <!-- ========================================== -->
            <div class="mt-8 pt-6 border-t border-gray-200 flex justify-center gap-4">
                <button type="button" class="px-8 py-2.5 bg-white border-2 border-gray-300 text-gray-700 rounded-lg font-semibold hover:bg-gray-50 hover:border-gray-400 transition-all shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-200 active:scale-95" onclick="$.magnificPopup.close();">
                    <i class="fas fa-times mr-2"></i> Hủy
                </button>
                <button type="button" style="background:blue!important" class="px-8 py-2.5 bg-brand-blue text-white rounded-lg font-semibold hover:bg-blue-800 transition-all shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 active:scale-95" onclick="_quotation.SeendEmail()">
                    <i class="fas fa-check mr-2"></i> Xác nhận
                </button>
            </div>
            <!-- ========================================== -->
        </div>
    </div>

</body>
