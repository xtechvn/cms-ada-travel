@{
    ViewData["Title"] = "Giữ phòng từ quỹ";
}
<style>
    .white-popup {
        max-width: 1600px !important;
        min-height: 500px !important;
    }
</style>

<section class="main-container">
    <div class="row-main container">
        <h2 class="title_page">Giữ phòng từ quỹ</h2>
        <div class="bg_white filter-search">
            <div class="row">
                <div class="col-md-2 mb10">
                    <input type="text" class="form-control" id="search-hotel-name" placeholder="Tên khách sạn" />
                </div>
                <div class="col-md-2 mb10">
                    <select class="form-control" id="search-status">
                        <option value="-1">Tất cả trạng thái</option>
                        <option value="0">Đang giữ</option>
                        <option value="1">Đã đặt</option>
                    </select>
                </div>
                <div class="col-md-8 mb10">
                    <button class="btn btn-default" onclick="userReserveHotelRoomFund.Search()">Tìm kiếm</button>
                    <button class="btn btn-success" onclick="userReserveHotelRoomFund.AddOrUpdate(0)">Thêm mới</button>
                    <button class="btn btn-primary" onclick="userReserveHotelRoomFund.CreateQuickOrder()">Tạo đơn hàng nhanh</button>
                </div>
            </div>
        </div>
        <div id="grid-user-reserve-hotel-room-fund">

        </div>
    </div>
</section>

@section scripts {
    <script src="~/modules/user_reserve_hotel_room_fund.js" asp-append-version="true"></script>
    <script src="~/modules/quick_order_fund.js" asp-append-version="true"></script>
}


