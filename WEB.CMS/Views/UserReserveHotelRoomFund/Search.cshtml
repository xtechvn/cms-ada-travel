@using Entities.ViewModels
@using System.Security.Claims
@model GenericViewModel<UserReserveHotelRoomFundViewModel>


<div class="table-responsive">
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th style="width: 40px;"></th>
                <th>STT</th>
                <th>Trạng thái</th>
                <th>Nhà cung cấp</th>
                <th>Khách sạn</th>
                <th>Hạng phòng</th>
                <th>Số phòng</th>
                <th>Từ ngày</th>
                <th>Đến ngày</th>
                <th>Người đặt</th>
                <th>Ngày tạo</th>
                <th>Giữ phòng đến</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.ListData != null && Model.ListData.Any())
            {
                int stt = (Model.CurrentPage - 1) * Model.PageSize + 1;
                long currentUserId = 0;
                if (User.FindFirst(ClaimTypes.NameIdentifier) != null)
                {
                    currentUserId = Convert.ToInt64(User.FindFirst(ClaimTypes.NameIdentifier).Value);
                }

                foreach (var item in Model.ListData)
                {
                    var keepUntil = item.CreatedDate?.AddHours(1);
                    var isExpired = keepUntil < DateTime.Now;
                    var isOrdered = item.Status == 1;
                    var isCancelled = item.Status == 2;

                    <tr class="reserve-row @(isOrdered ? "ordered-row" : "") @(isCancelled ? "cancelled-row" : "")" data-id="@item.Id" data-hotelid="@item.HotelId" data-supplierid="@item.SupplierId" data-keepuntil="@(keepUntil?.ToString("yyyy-MM-dd HH:mm:ss"))">
                        <td><input type="checkbox" class="check-reserve" value="@item.Id" @(isExpired || isOrdered || isCancelled ||item.UserId != currentUserId? "disabled" : "") /></td>
                        <td>@(stt++)</td>
                        <td>
                            @if (isOrdered)
                            {
                                <span class="status-green">Đã đặt</span>
                            }
                            else if (isExpired || isCancelled)
                            {
                                <span class="status-red">Hết hạn</span>
                            }
                            else
                            {
                                <span class="status-oranger">Đang giữ</span>
                            }
                        </td>
                        <td>@item.SupplierName</td>
                        <td>@item.HotelName</td>
                        <td>@item.RoomName</td>
                        <td>@item.NumberOfRooms</td>
                        <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.UserName</td>
                        <td>@item.CreatedDate?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.CreatedDate?.AddHours(1).ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            @if (!isOrdered && !isExpired && !isCancelled && item.UserId == currentUserId)
                            {
                                <button type="button" class="btn btn-default bg-main" onclick="userReserveHotelRoomFund.CancelReserve(@item.Id)">
                                    Bỏ giữ phòng
                                </button>
                            }
                        </td>
                    </tr>
                }
            }

            else
            {
                <tr>
                    <td colspan="13" class="text-center">Không có dữ liệu</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@await Component.InvokeAsync("PagingNew", new
    {

            pageModel = new Paging()
            {
                TotalRecord = Model.TotalRecord,
                TotalPage = Model.TotalPage,
                CurrentPage = Model.CurrentPage,
                PageSize = Model.PageSize,
                RecordName = "Giữ phòng từ quỹ",
                PageAction = "userReserveHotelRoomFund.ClientOnPaging({0})",
                PageSelectPageSize = "userReserveHotelRoomFund.onSelectPageSize()"
            }
        })
    </div>