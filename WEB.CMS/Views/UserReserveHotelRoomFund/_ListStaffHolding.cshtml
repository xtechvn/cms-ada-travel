@using Entities.ViewModels
@model GenericViewModel<UserReserveHotelRoomFundViewModel>

<div class="staff-holding-section">
    <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;margin-top: 15px;">
        <h3 class="section-title" style="font-size: 18px; font-weight: 700; color: #1a2a44; margin: 0; ">Danh sách nhân viên đang giữ quỹ</h3>
        <a href="/UserReserveHotelRoomFund/StaffFundManagement?hotelId=@ViewBag.HotelId&supplierId=@ViewBag.SupplierId" class="view-all" style="font-size: 13px; color: #2563eb; font-weight: 600; text-decoration: none;">Xem tất cả</a>
    </div>
    
    <div class="staff-list-wrapper" style="background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.05); border: 1px solid #eef2f7; overflow: hidden;">
        <table class="staff-list-table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 1px solid #eef2f7;">
                    <th style="padding: 14px 20px; text-align: left; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">NHÂN VIÊN</th>
                    <th style="padding: 14px 20px; text-align: left; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">HẠNG PHÒNG</th>
                    <th style="padding: 14px 20px; text-align: left; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">NGÀY bắt đầu</th>
                    <th style="padding: 14px 20px; text-align: left; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">NGÀY kết thúc</th>
                    <th style="padding: 14px 20px; text-align: center; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">SỐ LƯỢNG</th>
                    <th style="padding: 14px 20px; text-align: left; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">THỜI GIAN HẾT HẠN</th>
                    <th style="padding: 14px 20px; text-align: center; font-size: 11px; font-weight: 700; color: #8898aa; text-transform: uppercase; letter-spacing: 0.5px;">TRẠNG THÁI</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.ListData != null && Model.ListData.Any())
                {
                    foreach (var item in Model.ListData)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.2s;" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='white'">
                            <td style="padding: 14px 20px;">
                                <div class="user-info" style="display: flex; align-items: center; gap: 12px;">
                                    <div class="user-avatar" style="width: 32px; height: 32px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #64748b; font-size: 12px;">
                                        @if(!string.IsNullOrEmpty(item.UserName)) {
                                            <span>@item.UserName.Substring(0, 1).ToUpper()</span>
                                        } else {
                                            <i class="fa fa-user"></i>
                                        }
                                    </div>
                                    <span class="user-name" style="font-size: 14px; font-weight: 600; color: #1a2a44;">@item.UserName</span>
                                </div>
                            </td>
                            <td style="padding: 14px 20px; font-size: 14px; color: #475569;">@item.RoomName</td>
                            <td style="padding: 14px 20px; font-size: 14px; color: #475569;">@item.StartDate.ToString("dd/MM/yyyy")</td>
                            <td style="padding: 14px 20px; font-size: 14px; color: #475569;">@item.EndDate.ToString("dd/MM/yyyy")</td>
                            <td style="padding: 14px 20px; text-align: center; font-size: 15px; font-weight: 700; color: #1a2a44;">@item.NumberOfRooms.ToString("00")</td>
                            <td style="padding: 14px 20px;">
                                @{
                                    var expiry = item.CreatedDate?.AddHours(1);
                                    var isExpired = expiry < DateTime.Now;
                                }
                                <div class="expiry-time" style="display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: @(isExpired ? "#ef4444" : "#64748b");">
                                    <i class="fa fa-clock-o"></i>
                                    <span>@(expiry?.ToString("HH:mm - dd/MM/yyyy"))</span>
                                </div>
                            </td>
                            <td style="padding: 14px 20px; text-align: center;">
                                @if (item.Status == 0)
                                {
                                    if (isExpired)
                                    {
                                        <span class="status-red" >Hết hạn</span>
                                    }
                                    else
                                    {
                                        <span class="status-oranger" >Đang giữ</span>
                                    }
                                }
                                else if (item.Status == 1)
                                {
                                    <span class="status-green" >Đã đặt</span>
                                }
                                else if (item.Status == 2)
                                {
                                    <span class="status-red" >Hết hạn</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="padding: 40px; text-align: center; color: #94a3b8; font-style: italic; font-size: 14px;">
                            <i class="fa fa-info-circle" style="margin-right: 8px;"></i> Không có nhân viên nào đang giữ quỹ của khách sạn và nhà cung cấp này
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
