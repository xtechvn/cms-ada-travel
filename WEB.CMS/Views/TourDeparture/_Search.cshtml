@using Entities.ViewModels.Tourdepartureschedule
@model List<GetListTourDepartureModel>
@{
    var searchModel = (TourDepartureSeachModel)ViewBag.searchModel;
}

<style>
    .group-tour-header {
        background: #f8f9fa;
        padding: 10px 15px;
        border: 1px solid #dee2e6;
        border-bottom: none;
        display: flex;
        align-items: center;
        border-radius: 4px 4px 0 0;
        margin-top: 20px;
    }
    .group-tour-header h5 {
        margin: 0;
        font-weight: bold;
        color: #333;
        text-transform: uppercase;
        font-size: 15px;
    }
    .group-tour-header .badge {
        margin-left: 15px;
        padding: 5px 10px;
    }
    .table-group {
        border-radius: 0 0 4px 4px;
        margin-bottom: 20px;
    }
    .status-green { color: #28a745; font-weight: bold; }
    .status-oranger { color: #fd7e14; font-weight: bold; }
    .status-grey { color: #6c757d; }
</style>

@if (Model != null && Model.Any())
{
    var groupedData = Model.GroupBy(x => x.TourProductName).ToList();

    foreach (var group in groupedData)
    {
        var tourItems = group.ToList();
        <div class="group-tour-container">
            <div class="group-tour-header">
                <i class="fa fa-map-marker mr-2 text-primary"></i>
                <h5>@group.Key</h5>
                <span class="badge badge-info">@tourItems.Count Lịch khởi hành</span>
            </div>
            <div class="table-responsive bg_white table-group">
                <table class="table table-bordered table-hover mb-0">
                    <thead>
                        <tr class="bg-light">
                            <th style="width: 50px;" class="text-center">STT</th>
                            <th>Mã lịch trình</th>
                            <th class="text-center">Ngày khởi hành</th>
                            <th class="text-center">Hành trình</th>
                            <th class="text-right">Giá từ</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center">Slots</th>
                            <th class="text-center" style="width: 120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int innerStt = 0;
                        }
                        @foreach (var item in tourItems)
                        {
                            innerStt++;
                            <tr>
                                <td class="text-center">@innerStt</td>
                                <td>
                                    <a class="blue font-weight-bold" href="/TourDeparture/AddOrUpdate/@item.Id">
                                        #@item.Id
                                    </a>
                                </td>
                                <td class="text-center">
                                    <div class="font-weight-bold">@item.StartDate.ToString("dd/MM/yyyy HH:mm")</div>
                                    
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.StartPoint) || !string.IsNullOrEmpty(item.EndPoint))
                                    {
                                        <span>@(item.StartPoint ?? "---") <i class="fa fa-long-arrow-right mx-1"></i> @(item.EndPoint ?? "---")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa cập nhật</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <span class="bold text-primary">@item.adtAmount.ToString("N0")₫</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Status == 1)
                                    {
                                        <span class="badge badge-success">@item.Statusname</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">@item.Statusname</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex flex-column align-items-center">
                                        <div class="progress w-100" style="height: 6px; max-width: 100px;">
                                            <div class="progress-bar bg-info" role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="@(item.Total ?? 100)"></div>
                                        </div>
                                        <span class="small mt-1">0/@(item.Total ?? 0) slots</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <a href="/TourDeparture/AddOrUpdate/@item.Id" class="text-primary mr-2" title="Cập nhật">
                                        <i class="fa fa-edit" style="font-size: 18px;"></i>
                                    </a>
                                    <a class="text-info" title="Xem chi tiết" href="/TourDeparture/Detail/@item.Id">
                                        <i class="fa fa-eye" style="font-size: 18px;"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @await Component.InvokeAsync("Paging", new
    {
        pageModel = new Entities.ViewModels.Paging()
        {
            TotalRecord = Model.FirstOrDefault()?.TotalRow ?? 0,
            TotalPage = (int)Math.Ceiling((double)(Model.FirstOrDefault()?.TotalRow ?? 0) / searchModel.PageSize),
            CurrentPage = searchModel.PageIndex,
            PageSize = searchModel.PageSize,
            RecordName = "lịch trình",
            PageAction = "_tour_departure.OnPaging({0})"
        }
    })
}
else
{
    <div class="table-responsive bg_white border rounded p-3 text-center mt-3">
        <p class="mb-0">Không có dữ liệu hiển thị</p>
    </div>
}
