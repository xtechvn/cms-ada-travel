@{
    ViewData["Title"] = "Kho lịch trình khởi hành";
}

<section style="overflow-x: hidden;">
    <div class="row-main container">
        <h2 class="txt_18 bold mb20">Kho lịch trình khởi hành</h2>
        <div class="flex fillter-donhang">
            <a type="button" class="btn btn-default mb10 mr-2" href="/TourDeparture/AddOrUpdate/0">
                <i class="fa fa-plus"></i>Thêm mới
            </a>
            <div class="form-group mb10 mr-2">
                <input type="text" class="form-control" id="ip_search_tour_product" placeholder="Mã/Tên Tour..." style="width: 200px;">
            </div>
            
            <div class="form-group mb10 mr-2">
                <div class="datepicker-wrap" style="width:100%">
                    <input class="datepicker-input form-control" type="text" id="ip_search_date" placeholder="Thời gian khởi hành" />
                </div>
            </div>

            <div class="form-group mb10 mr-2" style="min-width: 200px;">
                <select class="select2" id="sl_search_status" style="width: 100%!important;">
                    <option value="-1">Trạng thái</option>
                    <option value="1">Hiển thị</option>
                    <option value="0">Ẩn</option>
                </select>
            </div>
            
            <div class="mb10 mr-2">
                <button type="button" class="btn btn-default bg-main" onclick="_tour_departure.OnSearch()">
                    <svg class="icon-svg" style="vertical-align: sub;">
                        <use xlink:href="/images/icons/icon.svg#search"></use>
                    </svg>
                    Tìm kiếm
                </button>
            </div>
        </div>
        <div class="line-bottom mb20"></div>
        <div class="wrap_bg wrap_bg_no-padding mb20" id="grid_data">
            <div class="col-xl-12 text-center" style="margin-top:200px">
                <img src="/images/icons/loading.gif" />
            </div>
        </div>
    </div>
</section>

@section scripts {
    <script type="text/javascript" src="~/modules/tour_departure.js"></script>
}
