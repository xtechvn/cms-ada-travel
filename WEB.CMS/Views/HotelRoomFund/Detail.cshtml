@using Entities.ViewModels
@model HotelRoomFundDetailViewModel

@{
    ViewData["Title"] = "Chi tiết quỹ phòng khách sạn";
    var dayNames = new Dictionary<DayOfWeek, string>
    {
        { DayOfWeek.Monday, "T2" },
        { DayOfWeek.Tuesday, "T3" },
        { DayOfWeek.Wednesday, "T4" },
        { DayOfWeek.Thursday, "T5" },
        { DayOfWeek.Friday, "T6" },
        { DayOfWeek.Saturday, "T7" },
        { DayOfWeek.Sunday, "CN" }
    };
}

<style>
    /* ===== HEADER INFO CARDS ===== */
    .fund-detail-header {
        display: flex;
        gap: 20px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }
    .fund-info-card {
        flex: 1;
        min-width: 220px;
        background: #fff;
        border-radius: 12px;
        padding: 20px 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border-left: 4px solid #1a2a44;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .fund-info-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }
    .fund-info-card .label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #8898aa;
        margin-bottom: 6px;
    }
    .fund-info-card .value {
        font-size: 20px;
        font-weight: 700;
        color: #1a2a44;
        line-height: 1.3;
    }
    .fund-info-card.hotel-card { border-left-color: #2563eb; }
    .fund-info-card.hotel-card .value { color: #2563eb; }
    .fund-info-card.total-card { border-left-color: #059669; }
    .fund-info-card.total-card .value { color: #059669; }

    /* ===== NAVIGATION ===== */
    .calendar-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        padding: 12px 20px;
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .calendar-nav .nav-btn {
        width: 38px;
        height: 38px;
        border: 2px solid #e2e8f0;
        background: #fff;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        color: #1a2a44;
        transition: all 0.2s;
    }
    .calendar-nav .nav-btn:hover {
        background: #1a2a44;
        color: #fff;
        border-color: #1a2a44;
    }
    .calendar-nav .nav-title {
        font-size: 16px;
        font-weight: 600;
        color: #1a2a44;
    }
    .calendar-nav .nav-today-btn {
        padding: 6px 16px;
        border: 2px solid #2563eb;
        background: transparent;
        color: #2563eb;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        font-size: 13px;
        transition: all 0.2s;
    }
    .calendar-nav .nav-today-btn:hover {
        background: #2563eb;
        color: #fff;
    }

    /* ===== CALENDAR TABLE ===== */
    .room-calendar-wrapper {
        background: #fff;
        border-radius: 12px;
        overflow-x: auto;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
        position: relative;
    }
    .room-calendar-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        min-width: 1000px; /* Đảm bảo bảng có chiều rộng tối thiểu để kích hoạt scroll */
    }
    .room-calendar-table thead th {
        background: #f8fafc;
        padding: 12px 10px;
        text-align: center;
        border-bottom: 2px solid #e2e8f0;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #8898aa;
        position: sticky;
        top: 0;
        z-index: 10;
        min-width: 85px;
    }
    .room-calendar-table thead th.th-room {
        text-align: left;
        padding-left: 24px;
        min-width: 250px;
        color: #1a2a44;
        font-size: 13px;
        position: sticky;
        left: 0;
        z-index: 20;
        background: #f8fafc;
    }
    .room-calendar-table thead th .day-number {
        display: block;
        font-size: 22px;
        font-weight: 700;
        color: #1a2a44;
        margin-top: 2px;
        line-height: 1.2;
    }
    .room-calendar-table thead th.is-today {
        background: #1a2a44;
        color: #fff;
        border-radius: 0;
    }
    .room-calendar-table thead th.is-today .day-number {
        color: #fff;
    }
    .room-calendar-table thead th.is-today .today-badge {
        display: inline-block;
        background: #fbbf24;
        color: #1a2a44;
        font-size: 9px;
        font-weight: 800;
        padding: 1px 8px;
        border-radius: 3px;
        margin-top: 4px;
        letter-spacing: 1px;
    }

    /* ===== ROOM ROW ===== */
    .room-calendar-table tbody tr {
        transition: background 0.15s;
    }
    .room-calendar-table tbody tr:hover {
        background: #f1f5f9;
        z-index: 1;
    }
    .room-calendar-table tbody td {
        padding: 16px 10px;
        text-align: center;
        border-bottom: 1px solid #eef2f7;
        vertical-align: middle;
        background: inherit;
    }
    .room-calendar-table tbody td.td-room {
        text-align: left;
        padding-left: 24px;
        position: sticky;
        left: 0;
        z-index: 15;
        background: #fff;
        border-right: 2px solid #e2e8f0;
    }
    .room-calendar-table tbody tr:hover td.td-room {
        background: #f1f5f9;
    }
    .room-name {
        font-size: 15px;
        font-weight: 700;
        color: #1a2a44;
        margin-bottom: 3px;
    }
    .room-capacity {
        font-size: 12px;
        color: #8898aa;
    }
    .room-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 8px;
        height: 28px;
        background: #1a2a44;
        border-radius: 4px;
        margin-right: 12px;
        vertical-align: middle;
    }

    /* ===== ALLOCATION CELL ===== */
    .alloc-cell {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 72px;
        height: 40px;
        border-radius: 8px;
        border: 2px solid #e2e8f0;
        font-size: 14px;
        font-weight: 700;
        color: #1a2a44;
        background: #fff;
        transition: all 0.2s;
        cursor: default;
        position: relative;
    }
    .alloc-cell.level-low {
        border-color: #d1d5db;
        color: #374151;
        background: #f9fafb;
    }
    .alloc-cell.level-medium {
        border-color: #fbbf24;
        color: #92400e;
        background: #fffbeb;
    }
    .alloc-cell.level-high {
        border-color: #dc2626;
        color: #dc2626;
        background: #fef2f2;
    }
    .alloc-cell.level-full {
        border-color: #dc2626;
        color: #fff;
        background: #dc2626;
    }
    .alloc-cell.is-today-cell {
        box-shadow: 0 0 0 2px #1a2a44;
    }

    /* ===== EMPTY STATE ===== */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: #8898aa;
    }
    .empty-state i {
        font-size: 48px;
        margin-bottom: 16px;
        display: block;
        opacity: 0.4;
    }
    .empty-state p {
        font-size: 16px;
    }

    /* ===== BACK BUTTON ===== */
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        background: #f1f5f9;
        color: #1a2a44;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-weight: 600;
        font-size: 13px;
        text-decoration: none;
        transition: all 0.2s;
        margin-bottom: 20px;
    }
    .btn-back:hover {
        background: #1a2a44;
        color: #fff;
        border-color: #1a2a44;
        text-decoration: none;
    }
    .white-popup{
        max-width: 1200px!important;
        min-height: 500px!important;
    }
    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .fund-detail-header { flex-direction: column; }
        .fund-info-card { min-width: 100%; }
        .room-calendar-wrapper { overflow-x: auto; }
    }
</style>

<section class="main-container">
    <div class="row-main container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <a href="/HotelRoomFund" class="btn-back" style="margin-bottom: 0;">
                <i class="fa fa-arrow-left"></i> Quay lại danh sách
            </a>
            <div style="display: flex; gap: 8px;">
                <button type="button" class="btn btn-success" onclick="fundDetailPage.Reserve()" style="border-radius: 8px; font-weight: 600; padding: 8px 24px;">
                    <i class="fa fa-lock"></i> Giữ phòng
                </button>
                @if(ViewBag.Edit==1){
                    <button type="button" class="btn btn-primary" onclick="fundDetailPage.Edit()" style="border-radius: 8px; font-weight: 600; padding: 8px 24px;">
                        <i class="fa fa-edit"></i> Chỉnh sửa quỹ
                    </button>
                }
            </div>
        </div>
        <input type="hidden" id="detail-hotel-id" value="@Model.HotelId" />
        <input type="hidden" id="detail-supplier-id" value="@Model.SupplierId" />

        <h2 class="title_page">Chi tiết quỹ phòng khách sạn</h2>

        <!-- Info Cards -->
        <div class="fund-detail-header">
            <div class="fund-info-card">
                <div class="label">Nhà cung cấp</div>
                <div class="value">@(Model.SupplierName ?? "N/A")</div>
            </div>
            <div class="fund-info-card hotel-card">
                <div class="label">Khách sạn</div>
                <div class="value">@(Model.HotelName ?? "N/A")</div>
            </div>
            <div class="fund-info-card total-card">
                <div class="label">Tổng số phòng</div>
                <div class="value">@(Model.TotalRooms?.ToString("N0") ?? "0")</div>
            </div>
        </div>

       

        <!-- Calendar Navigation -->
        <div class="calendar-nav">
            <button class="nav-btn" id="btn-prev-week" title="Tuần trước">
                <i class="fa fa-chevron-left"></i>
            </button>
            <div style="display: flex; align-items: center; gap: 16px;">
                <div class="nav-datepicker-wrapper" style="position: relative;">
                    <input type="text" id="datepicker-nav" class="form-control" style="width: 220px; font-weight: 600; text-align: center; cursor: pointer; border-radius: 8px; border: 2px solid #e2e8f0;" readonly />
                    <i class="fa fa-calendar" style="position: absolute; right: 12px; top: 11px; color: #8898aa; pointer-events: none;"></i>
                </div>
                <button class="nav-today-btn" id="btn-today">Hôm nay</button>
            </div>
            <button class="nav-btn" id="btn-next-week" title="Tuần sau">
                <i class="fa fa-chevron-right"></i>
            </button>
        </div>

        <!-- Calendar Grid -->
        <div class="room-calendar-wrapper">
            <div id="calendar-grid-container">
                <table class="room-calendar-table" id="room-calendar-table">
                    <thead>
                        <tr>
                            <th class="th-room">HẠNG PHÒNG</th>
                            @foreach (var date in Model.DisplayDates)
                            {
                                var isToday = date.Date == DateTime.Today;
                                <th class="@(isToday ? "is-today" : "")">
                                    @dayNames[date.DayOfWeek]
                                    <span class="day-number">@date.Day.ToString("00")</span>
                                    @if (isToday)
                                    {
                                        <span class="today-badge">HÔM NAY</span>
                                    }
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RoomCategories != null && Model.RoomCategories.Any())
                        {
                            foreach (var room in Model.RoomCategories)
                            {
                                <tr>
                                    <td class="td-room">
                                        <div style="display: flex; align-items: center;">
                                            <span class="room-icon"></span>
                                            <div>
                                                <div class="room-name">@room.RoomName</div>
                                                <div class="room-capacity">Capacity: @room.TotalCapacity.ToString("N0") phòng</div>
                                            </div>
                                            <div style="margin-left: auto;">
                                               <button type="button" class="btn btn-default btn-xs" onclick="fundDetailPage.ReserveRoom(@room.HotelRoomId)" title="Giữ phòng này">
                                                   <i class="fa fa-lock text-success"></i>
                                               </button>
                                            </div>
                                        </div>
                                    </td>
                                    @foreach (var date in Model.DisplayDates)
                                    {
                                        var allocated = room.DailyAllocations.ContainsKey(date) ? room.DailyAllocations[date] : 0;
                                        var booked = room.DailyBooked.ContainsKey(date) ? room.DailyBooked[date] : 0;
                                        var percentage = allocated > 0 ? Math.Round((booked / allocated) * 100, 0) : 0;
                                        var level = "level-low";
                                        if (percentage >= 100) level = "level-full";
                                        else if (percentage >= 80) level = "level-high";
                                        else if (percentage >= 50) level = "level-medium";
                                        var isToday = date.Date == DateTime.Today;

                                        <td>
                                            <div class="alloc-cell @level @(isToday ? "is-today-cell" : "")"
                                                 title="Đã đặt: @booked.ToString("N0") / Quỹ: @allocated.ToString("N0") (@percentage%)">
                                                 @booked.ToString("N0")/ @allocated.ToString("N0")
                                            </div>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(Model.DisplayDates.Count + 1)">
                                    <div class="empty-state">
                                        <i class="fa fa-calendar-o"></i>
                                        <p>Chưa có dữ liệu quỹ phòng cho khoảng thời gian này</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

         <!-- Staff Holding Fund List -->
        <div id="staff-holding-container" style="margin-bottom: 30px;margin-top: 15px;">
            <div style="padding: 20px; text-align: center; color: #8898aa;">
                <i class="fa fa-spinner fa-spin"></i> Đang tải danh sách nhân viên...
            </div>
        </div>
    </div>
</section>


<input type="hidden" id="fund-id" value="@Model.Id" />

@section scripts {
    <script src="~/modules/hotel_room_fund.js" asp-append-version="true"></script>
    <script src="~/modules/hotel_room_fund_detail.js" asp-append-version="true"></script>
    <script src="~/modules/user_reserve_hotel_room_fund.js" asp-append-version="true"></script>
}
